---
import type { Lang } from "../i18n/index";
import { t } from "../i18n/common";

interface Props {
  heading: string;
  text: string;
  features?: string[];
  lang?: Lang;
}

const { heading, text, features, lang = "en" } = Astro.props;
---

<details class="px-4 py-2 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-sm">
  <summary class="cursor-pointer text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] select-none">
    {heading}
  </summary>
  <div class="mt-2 text-[var(--color-text-muted)] space-y-2 pb-2">
    <p>{text}</p>
    {features && features.length > 0 && (
      <ul class="list-disc list-inside space-y-1">
        {features.map((f) => <li>{f}</li>)}
      </ul>
    )}
    <p class="text-xs">{t(lang, "seoBlockPrivacy")}</p>
  </div>
</details>
