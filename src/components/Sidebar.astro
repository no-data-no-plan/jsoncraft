---
import { tools } from "../lib/tools";
import type { Lang } from "../i18n/index";
import { localePath } from "../i18n/index";
import { t, translateGroup } from "../i18n/common";
import { getToolName } from "../i18n/tools";

interface Props {
  activeToolId: string;
  lang?: Lang;
}

const { activeToolId, lang = "en" } = Astro.props;

const groups = [
  { label: "Core", ids: ["formatter", "diff", "viewer", "jsonpath"] },
  {
    label: "Converters",
    ids: [
      "yaml-to-json",
      "json-to-yaml",
      "json-to-csv",
      "csv-to-json",
      "json-to-toml",
      "toml-to-json",
      "json-to-typescript",
      "json-to-html-table",
    ],
  },
  {
    label: "Dev Tools",
    ids: ["regex", "base64", "url-encode", "hash", "uuid", "timestamp", "cron", "xml-formatter", "yaml-validator", "json-schema-validator"],
  },
];
---

<aside
  id="sidebar"
  class="w-60 shrink-0 bg-[var(--color-bg-secondary)] border-r border-[var(--color-border)] flex flex-col
         fixed lg:static inset-y-0 left-0 z-40 -translate-x-full lg:translate-x-0 transition-transform"
>
  <!-- Logo -->
  <a href={localePath("/", lang)} class="flex items-center gap-2 px-4 py-3 border-b border-[var(--color-border)]">
    <span class="text-xl font-bold text-[var(--color-accent-fg)]">{ }</span>
    <span class="text-lg font-bold text-[var(--color-text-primary)]">JSONCraft</span>
  </a>

  <!-- Docs nav -->
  <div class="px-3 pt-2 pb-1">
    <a
      href={lang === "es" ? "/es/docs/" : "/docs/"}
      aria-current={activeToolId === "docs" ? "page" : undefined}
      class:list={[
        "flex items-center gap-2 px-2 py-1.5 min-h-[44px] text-xs font-medium rounded transition-colors",
        activeToolId === "docs"
          ? "text-[var(--color-accent-fg)] bg-[var(--color-bg-tertiary)]"
          : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]",
      ]}
    >
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 2h7l3 3v9a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
        <path d="M10 2v3h3M5 8h6M5 11h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span>{lang === "es" ? "Guías" : "Guides"}</span>
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto overflow-x-hidden py-2">
    {
      groups.map((group) => (
        <div class="mb-2">
          <div class="px-4 py-1 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
            {translateGroup(group.label, lang)}
          </div>
          {group.ids.map((id) => {
            const tool = tools.find((t) => t.id === id)!;
            const isActive = tool.id === activeToolId;
            return (
              <a
                href={localePath(tool.path, lang)}
                draggable="false"
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "flex items-center gap-2 px-4 py-1.5 mx-2 min-h-[44px] rounded text-sm transition-colors",
                  isActive
                    ? "bg-[var(--color-accent)]/15 text-[var(--color-accent-fg)] font-medium"
                    : "text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-tertiary)] hover:text-[var(--color-text-primary)]",
                ]}
              >
                <span class="w-7 text-center font-mono text-xs opacity-80">{tool.icon}</span>
                <span>{getToolName(tool.id, lang)}</span>
              </a>
            );
          })}
        </div>
      ))
    }
  </nav>

  <!-- Bottom info -->
  <div class="px-4 border-t border-[var(--color-border)] text-[11px] text-[var(--color-text-muted)]" style="padding-top: 15px; padding-bottom: 15px;">
    {t(lang, "sidebarPrivacy")}
  </div>
</aside>
