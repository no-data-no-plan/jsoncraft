---
/**
 * SourcesBlock — collapsible <details> block listing the canonical
 * specifications + standards a tool implements (Stanford Web Credibility
 * #1: "Make it easy to verify the accuracy of information").
 *
 * Ported from CV's compoundvision/SourcesBlock.astro 2026-05-15.
 * Adaptation:
 *  - JC i18n pattern: t(lang, "sourcesHeading") instead of getCommon's c.key
 *  - JC token names: --color-bg-primary / --color-text-muted (CV used
 *    --color-bg / --color-text-dim)
 *  - JC accent: --color-accent-fg (light blue) instead of CV's --color-amber
 *    for the summary text
 *
 * Renders nothing if the tool has no sources entry — safe to drop on any
 * tool page; tools without canonical specs (viewer, diff, graph) just
 * skip rendering.
 */
import { getSources } from "../data/sources";
import { t } from "../i18n/common";
import type { Lang } from "../i18n/index";

interface Props {
  slug: string;
  lang?: Lang;
}

const { slug, lang = "en" } = Astro.props;
const sources = getSources(slug);
---

{sources.length > 0 && (
  <details
    class="px-6 py-3 border-t border-[var(--color-border)] text-sm"
    style="background: var(--color-bg-primary);"
  >
    <summary
      class="cursor-pointer text-xs font-mono select-none"
      style="color: var(--color-accent-fg); letter-spacing: 0.05em;"
    >
      {t(lang, "sourcesHeading")} ({sources.length})
    </summary>
    <ul class="mt-3 list-none space-y-2 pb-1 pl-0">
      {sources.map((s) => (
        <li class="text-xs leading-relaxed" style="color: var(--color-text-muted);">
          <cite class="not-italic">
            {s.authors} ({s.year}). {s.title}.{s.venue && ` ${s.venue}.`}
          </cite>
        </li>
      ))}
    </ul>
    <p class="mt-2 text-[10px]" style="color: var(--color-text-muted);">
      {t(lang, "sourcesNote")}
    </p>
  </details>
)}
