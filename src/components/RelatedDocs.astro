---
import { getDocsReferencingTool, docPath } from "../lib/docs";
import type { Lang } from "../i18n/index";

interface Props {
  toolId: string;
  lang?: Lang;
}

const { toolId, lang = "en" } = Astro.props;
const docs = await getDocsReferencingTool(toolId, lang, 4);
const heading = lang === "es" ? "Guías relacionadas" : "Related guides";
---

{docs.length > 0 && (
  <section class="px-4 py-3 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
    <h2 class="text-sm font-semibold text-[var(--color-text-primary)] mb-2">{heading}</h2>
    <ul class="space-y-1.5">
      {docs.map((doc) => (
        <li>
          <a
            href={docPath(doc)}
            class="block text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent-fg)] transition-colors"
          >
            <span class="font-medium text-[var(--color-text-primary)]">{doc.data.title}</span>
            <span class="block text-[var(--color-text-muted)] mt-0.5 opacity-80">{doc.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
