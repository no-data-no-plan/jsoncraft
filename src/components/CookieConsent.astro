---
/*
 * Consent management is handled by Google's Funding Choices CMP (loaded in
 * Layout.astro <head>). This component only exposes a "Cookie preferences"
 * button that re-opens the Google consent dialog so users can withdraw or
 * change their choice at any time (GDPR Art. 7(3): withdrawing consent must
 * be as easy as giving it).
 *
 * Google's CMP only shows UI for users in regulated regions (EEA / UK / CH /
 * California). For other users, the button is a no-op — which is fine.
 */
import type { Lang } from "../i18n/index";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const label = lang === "es" ? "Preferencias de cookies" : "Cookie preferences";
---

<button
  id="cookie-prefs-btn"
  class="hover:text-[var(--color-accent)] transition-colors"
  aria-label={label}
  type="button"
>{label}</button>

<script is:inline>
  document.getElementById("cookie-prefs-btn")?.addEventListener("click", function() {
    // Google Funding Choices exposes `googlefc.showRevocationMessage()` once
    // the CMP script has initialized. Fall back to alert for users whose
    // region means the CMP never loaded (non-regulated).
    if (window.googlefc && typeof window.googlefc.showRevocationMessage === "function") {
      window.googlefc.showRevocationMessage();
    } else if (window.googlefc && window.googlefc.callbackQueue) {
      window.googlefc.callbackQueue.push({
        'CONSENT_DATA_READY': function() {
          if (typeof window.googlefc.showRevocationMessage === "function") {
            window.googlefc.showRevocationMessage();
          }
        }
      });
    } else {
      // Non-regulated region: no consent UI to reopen. Show inline toast
      // instead of native alert() — Nielsen audit flagged the alert() as
      // jarring (Phase 5.1, 2026-04-30).
      var msg = document.documentElement.lang === "es"
        ? "No se muestra diálogo de consentimiento en tu región porque no es obligatorio por GDPR/CCPA. Puedes gestionar cookies desde la configuración de tu navegador."
        : "No consent dialog is shown in your region because GDPR/CCPA don't apply. You can manage cookies from your browser settings.";
      showCookieInfoToast(msg);
    }
  });

  function showCookieInfoToast(text) {
    var toast = document.createElement("div");
    toast.setAttribute("role", "status");
    toast.setAttribute("aria-live", "polite");
    toast.textContent = text;
    Object.assign(toast.style, {
      position: "fixed", bottom: "24px", left: "50%",
      transform: "translate(-50%, 20px)", padding: "14px 20px",
      borderRadius: "8px", background: "var(--color-bg-secondary, #1a1a1a)",
      color: "var(--color-text-primary, #e8e8e8)",
      border: "1px solid var(--color-border, #2a2a2a)",
      fontSize: "13px", lineHeight: "1.5",
      boxShadow: "0 4px 20px rgba(0,0,0,0.4)",
      maxWidth: "min(420px, calc(100vw - 2rem))",
      zIndex: "9999", opacity: "0",
      transition: "opacity .2s ease, transform .2s ease",
      cursor: "pointer",
    });
    toast.title = document.documentElement.lang === "es" ? "Clic para cerrar" : "Click to dismiss";
    document.body.appendChild(toast);
    requestAnimationFrame(function () {
      toast.style.opacity = "1";
      toast.style.transform = "translate(-50%, 0)";
    });
    var dismissed = false;
    function dismiss() {
      if (dismissed) return;
      dismissed = true;
      toast.style.opacity = "0";
      toast.style.transform = "translate(-50%, 20px)";
      setTimeout(function () { toast.remove(); }, 220);
    }
    toast.addEventListener("click", dismiss);
    setTimeout(dismiss, 6000);
  }
</script>
