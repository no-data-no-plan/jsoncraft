---
import { tools } from "../lib/tools";
import type { Lang } from "../i18n/index";

interface Props {
  toolIds: string[];
  lang?: Lang;
}

const { toolIds, lang = "en" } = Astro.props;
const resolved = toolIds
  .map((id) => tools.find((t) => t.id === id))
  .filter(Boolean) as typeof tools;

const heading = lang === "es" ? "Herramientas relacionadas" : "Related tools";
const openLabel = lang === "es" ? "Abrir" : "Open";
const pathFor = (path: string) => (lang === "es" ? `/es${path}` : path);
---

{resolved.length > 0 && (
  <section class="mt-8 pt-6 border-t border-[var(--color-border)]">
    <h2 class="text-sm font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-3">{heading}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {resolved.map((tool) => (
        <a
          href={pathFor(tool.path)}
          class="block p-3 rounded border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors bg-[var(--color-bg-secondary)]"
        >
          <div class="flex items-start justify-between gap-2">
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-[var(--color-text-primary)] mb-1">{tool.name}</div>
              <div class="text-xs text-[var(--color-text-muted)] line-clamp-2">{tool.description}</div>
            </div>
            <span class="text-xs text-[var(--color-accent-fg)] shrink-0">{openLabel} →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
