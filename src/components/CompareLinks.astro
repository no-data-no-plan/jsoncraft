---
// Renders a row of "Compare with X" links pointing to our /vs-*/ comparison
// pages. Used to surface comparison content from related tool pages so the
// comparison URLs stop being orphaned (they were only reachable via SERP).
//
// Usage:
//   <CompareLinks lang="en" competitors={["codebeautify", "jsonlint"]} />

import type { Lang } from "../i18n/index";

interface Props {
  lang?: Lang;
  competitors: string[];
}

const { lang = "en", competitors } = Astro.props;
const prefix = lang === "es" ? "/es" : "";

// Competitor display names + URL slugs. Slug is the vs-*.astro filename stem.
const COMPETITORS: Record<string, { name: string; slug: string }> = {
  codebeautify: { name: "CodeBeautify", slug: "vs-codebeautify" },
  devtoys: { name: "DevToys", slug: "vs-devtoys" },
  "json-crack": { name: "JSON Crack", slug: "vs-json-crack" },
  "json-editor-online": { name: "JSON Editor Online", slug: "vs-json-editor-online" },
  jsonlint: { name: "JSONLint", slug: "vs-jsonlint" },
};

const items = competitors
  .map((key) => COMPETITORS[key])
  .filter((c): c is { name: string; slug: string } => Boolean(c));

const label = lang === "es" ? "Compara con" : "Compare with";
---

{items.length > 0 && (
  <section class="px-6 py-4 border-t border-[var(--color-border)]">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-[10px] font-mono uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
        {label}
      </span>
      {items.map((c) => (
        <a
          href={`${prefix}/${c.slug}/`}
          class="text-[10px] font-mono px-2 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-colors no-underline"
        >
          vs {c.name}
        </a>
      ))}
    </div>
  </section>
)}
