---
import { tools } from "../lib/tools";
import type { Lang } from "../i18n/index";
import { localePath } from "../i18n/index";
import { t } from "../i18n/common";
import { getToolName } from "../i18n/tools";

interface Props {
  heading: string;
  text: string;
  relatedToolIds: string[];
  lang?: Lang;
}

const { heading, text, relatedToolIds, lang = "en" } = Astro.props;
const relatedTools = relatedToolIds
  .map((id) => tools.find((t) => t.id === id))
  .filter(Boolean) as typeof tools;
---

<section class="px-4 py-3 border-t border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <h2 class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">{heading}</h2>
  <p class="text-xs text-[var(--color-text-muted)] leading-relaxed mb-2">{text}</p>
  {relatedTools.length > 0 && (
    <div class="flex flex-wrap gap-2">
      <span class="text-xs text-[var(--color-text-muted)]">{t(lang, "related")}</span>
      {relatedTools.map((tool) => (
        <a
          href={localePath(tool.path, lang)}
          class="text-xs text-[var(--color-accent-fg)] hover:underline"
        >
          {getToolName(tool.id, lang)}
        </a>
      ))}
    </div>
  )}
</section>
