---
/**
 * Visible SEO content block — renders H2 + description + related tool links
 * below the tool component. Not intrusive, informative footer style.
 */
import { tools } from "../lib/tools";

interface Props {
  heading: string;
  text: string;
  relatedToolIds: string[];
}

const { heading, text, relatedToolIds } = Astro.props;
const relatedTools = relatedToolIds
  .map((id) => tools.find((t) => t.id === id))
  .filter(Boolean) as typeof tools;
---

<section class="px-4 py-3 border-t border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <h2 class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">{heading}</h2>
  <p class="text-xs text-[var(--color-text-muted)] leading-relaxed mb-2">{text}</p>
  {relatedTools.length > 0 && (
    <div class="flex flex-wrap gap-2">
      <span class="text-xs text-[var(--color-text-muted)]">Related:</span>
      {relatedTools.map((tool) => (
        <a
          href={tool.path}
          class="text-xs text-[var(--color-accent)] hover:underline"
        >
          {tool.name}
        </a>
      ))}
    </div>
  )}
</section>
