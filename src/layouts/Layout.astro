---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import CrossLinks from "../components/CrossLinks.astro";
import CookieConsent from "../components/CookieConsent.astro";
import LangToggle from "../components/LangToggle.astro";
import { tools } from "../lib/tools";
import type { Lang } from "../i18n/index";
import { getAlternatePath } from "../i18n/index";
import { t } from "../i18n/common";
import { getHowTo } from "../i18n/howto";
import { faqs } from "../i18n/faq";

interface Props {
  title: string;
  description: string;
  activeToolId: string;
  lang?: Lang;
}

const { title, description, activeToolId, lang = "en" } = Astro.props;
const fullTitle = `${title} | JSONCraft`;
const pathWithTrailing = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalUrl = `https://jsoncraft.dev${pathWithTrailing}`;
const alternatePath = getAlternatePath(Astro.url.pathname);
const alternateUrl = `https://jsoncraft.dev${alternatePath.endsWith('/') ? alternatePath : alternatePath + '/'}`;
const activeTool = tools.find((t) => t.id === activeToolId);

// The landing page at `/` passes activeToolId="home". Tool pages pass
// their tool id (e.g. "formatter", "diff"). isHome controls schema
// selection (WebSite + Organization + FAQPage instead of
// SoftwareApplication) and skips breadcrumb + HowTo emission.
const isHome = activeToolId === "home";

// Page-type detection for schema-appropriate markup:
// - /privacy-policy/ → WebPage (NOT SoftwareApplication, activeToolId="" is passed)
// - /vs-*/ comparison pages → WebPage (each page adds Article schema inline)
// - All other tool pages → SoftwareApplication
const normalizedPath = Astro.url.pathname.replace(/^\/es\//, '/').replace(/\/$/, '');
const isLegalPage = normalizedPath === "/privacy-policy";
const isComparePage = normalizedPath.startsWith("/vs-");

// OpenGraph type: website for home/legal, article for tool and compare pages
const ogType = (isHome || isLegalPage) ? "website" : "article";
const ogLocale = lang === "es" ? "es_ES" : "en_US";
const ogLocaleAlternate = lang === "es" ? "en_US" : "es_ES";

type SchemaObject = Record<string, unknown>;

const primarySchema: SchemaObject = (isLegalPage || isComparePage)
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "url": canonicalUrl,
      "description": description,
      "inLanguage": lang,
      "isPartOf": { "@type": "WebSite", "name": "JSONCraft", "url": "https://jsoncraft.dev" },
    }
  : {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": title,
      "url": canonicalUrl,
      "description": description,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "isPartOf": { "@type": "WebApplication", "name": "JSONCraft", "url": "https://jsoncraft.dev" },
    };

const schemas: SchemaObject[] = [primarySchema];

// BreadcrumbList: only emit for non-home pages (home with 1 item is invalid
// for rich results; Google requires ≥2 items in BreadcrumbList). position 1
// URL uses explicit trailing slash to match canonical.
if (!isHome) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "JSONCraft", "item": `https://jsoncraft.dev${lang === "es" ? "/es/" : "/"}` },
      { "@type": "ListItem", "position": 2, "name": title, "item": canonicalUrl },
    ],
  });
}

// HowTo schema for tool pages — eligible for Google HowTo rich results.
// Skip for legal pages, compare pages, and home (home has FAQPage instead).
// HowTo steps are defined per tool in src/i18n/howto.ts.
if (!isLegalPage && !isComparePage && !isHome) {
  const howto = getHowTo(activeToolId, lang);
  if (howto) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": howto.name,
      "description": description,
      "inLanguage": lang,
      "tool": [{ "@type": "HowToTool", "name": `JSONCraft ${title.split(' — ')[0].split(' | ')[0]}` }],
      "step": howto.steps.map((s, i) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "name": s.name,
        "text": s.text,
      })),
    });
  }
}

// FAQPage schema for top tool pages (top 5 tools defined in i18n/faq.ts).
if (!isLegalPage && !isComparePage && !isHome && faqs[activeToolId]) {
  const faqContent = faqs[activeToolId][lang];
  if (faqContent) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "inLanguage": lang,
      "mainEntity": faqContent.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": { "@type": "Answer", "text": f.answer },
      })),
    });
  }
}

if (isHome) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "JSONCraft",
    "url": "https://jsoncraft.dev",
    "description": "Free online JSON, YAML, CSV, TOML tools. Format, diff, convert, validate — no signup, runs in your browser.",
    "inLanguage": ["en", "es"],
  });

  schemas.push({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "JSONCraft",
    "url": "https://jsoncraft.dev",
    "logo": "https://jsoncraft.dev/og-image.png",
    "description": "Free, privacy-first suite of 23 developer tools for JSON, YAML, CSV, TOML, XML, and more. Format, diff, convert, validate — 100% client-side in your browser.",
    "sameAs": [
      "https://buymeacoffee.com/allopen",
    ],
  });

  const faqEN = [
    {
      question: "What is the best free online JSON formatter?",
      answer: "JSONCraft is a free suite of 23 developer tools that includes a JSON formatter, validator, diff viewer, and converters for YAML, CSV, TOML, and TypeScript. All tools run entirely in the browser with no data uploaded to any server.",
    },
    {
      question: "Is there a free JSON validator that works offline?",
      answer: "JSONCraft is browser-based and works without an internet connection after the initial page load. It validates JSON in real time, showing the exact line and column of any syntax error.",
    },
    {
      question: "What free alternative to Postman exists for JSON formatting?",
      answer: "JSONCraft provides JSON formatting, validation, beautification, and minification without requiring an account or installation. It handles formatting and validation tasks that developers commonly use Postman for, directly in the browser.",
    },
    {
      question: "Can I convert JSON to YAML or CSV online for free?",
      answer: "Yes. JSONCraft includes bidirectional converters for JSON to YAML, JSON to CSV, JSON to TOML, and JSON to TypeScript interfaces. All conversions happen client-side with no data leaving your browser.",
    },
    {
      question: "Is there a free JSONPath tester online?",
      answer: "JSONCraft includes a JSONPath tool with live evaluation. You can paste your JSON, write a JSONPath expression, and instantly see the matching results highlighted in real time.",
    },
  ];

  const faqES = [
    {
      question: "Cual es el mejor formateador JSON online gratuito?",
      answer: "JSONCraft es un conjunto gratuito de 23 herramientas para desarrolladores que incluye formateador JSON, validador, visor de diferencias y conversores para YAML, CSV, TOML y TypeScript. Todas las herramientas se ejecutan completamente en el navegador sin enviar datos a ningun servidor.",
    },
    {
      question: "Existe un validador JSON gratuito que funcione sin conexion?",
      answer: "JSONCraft funciona en el navegador y no necesita conexion a internet despues de la carga inicial. Valida JSON en tiempo real, mostrando la linea y columna exactas de cualquier error de sintaxis.",
    },
    {
      question: "Que alternativa gratuita a Postman existe para formatear JSON?",
      answer: "JSONCraft ofrece formateo, validacion, embellecimiento y minificacion de JSON sin necesidad de cuenta ni instalacion. Maneja las tareas de formateo y validacion que los desarrolladores suelen usar Postman para realizar, directamente en el navegador.",
    },
    {
      question: "Puedo convertir JSON a YAML o CSV online gratis?",
      answer: "Si. JSONCraft incluye conversores bidireccionales de JSON a YAML, JSON a CSV, JSON a TOML y JSON a interfaces TypeScript. Todas las conversiones se realizan en el cliente sin que los datos salgan de tu navegador.",
    },
    {
      question: "Existe un probador de JSONPath online gratuito?",
      answer: "JSONCraft incluye una herramienta JSONPath con evaluacion en vivo. Puedes pegar tu JSON, escribir una expresion JSONPath y ver instantaneamente los resultados coincidentes resaltados en tiempo real.",
    },
  ];

  const faqItems = lang === "es" ? faqES : faqEN;
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  });
}

const jsonLd = JSON.stringify(schemas);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />
    <meta name="google-adsense-account" content="ca-pub-8761907366448308" />

    <!-- Google Analytics 4 — Consent Mode v2. Default deny all; CMP updates signals. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
      gtag('js', new Date());
      gtag('config', 'G-PV8S3GBCDY', { anonymize_ip: true });
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PV8S3GBCDY"></script>

    <!-- Preconnect to AdSense origins to shave ~50-100ms off the first ad request -->
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://adservice.google.com" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={lang === "en" ? canonicalUrl : alternateUrl} />
    <link rel="alternate" hreflang="es" href={lang === "es" ? canonicalUrl : alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={lang === "en" ? canonicalUrl : alternateUrl} />

    <!-- Preload critical font (Inter latin) to improve LCP -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:site_name" content="JSONCraft" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://jsoncraft.dev/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://jsoncraft.dev/og-image.png" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Blocking: apply theme before body paints to prevent flash -->
    <script is:inline>
      if (localStorage.getItem("jsoncraft-theme") === "light") {
        document.documentElement.classList.add("light");
      }
    </script>
  </head>
  <body class="flex min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:rounded focus:text-sm focus:font-medium" style="background: var(--color-accent); color: #fff;">Skip to content</a>
    <Sidebar activeToolId={activeToolId} lang={lang} />

    <div class="flex flex-1 flex-col min-w-0">
      <!-- Header -->
      <header
        class="flex items-center justify-between px-4 py-2 border-b border-[var(--color-border)] bg-[var(--color-bg-secondary)]"
      >
        <div class="flex items-center gap-3">
          <button
            id="menu-toggle"
            class="lg:hidden p-2 rounded hover:bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)]"
            aria-label={t(lang, "toggleMenu")}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          {(isLegalPage || isHome || isComparePage) ? (
            <span class="text-lg font-semibold text-[var(--color-text-primary)]">{title}</span>
          ) : (
            <h1 class="text-lg font-semibold text-[var(--color-text-primary)]">{title}</h1>
          )}
        </div>

        <div class="flex items-center gap-2" style="min-height: 36px;">
          <span class="hidden sm:inline text-xs text-[var(--color-text-muted)]" style="min-width: 195px;">
            {t(lang, "headerBadge")}
          </span>
          <LangToggle
            lang={lang}
            enPath={lang === "en" ? Astro.url.pathname : alternatePath}
            esPath={lang === "es" ? Astro.url.pathname : alternatePath}
          />
          <button
            id="theme-toggle"
            class="p-2 rounded hover:bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)]"
            aria-label={t(lang, "toggleTheme")}
          >
            <svg id="icon-dark" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              />
            </svg>
            <svg id="icon-light" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
              />
            </svg>
          </button>
        </div>
      </header>

      <!-- Main content -->
      <main id="main-content" class="flex-1 flex flex-col overflow-hidden">
        <slot />
        <!-- Ad banner -->
        <div class="shrink-0 px-6 py-3 border-t border-[var(--color-border)]" style="min-height: 100px;">
          <div class="mx-auto max-w-[728px]" style="min-height: 90px;">
            <ins class="adsbygoogle"
                 style="display:block; min-height: 90px;"
                 data-ad-client="ca-pub-8761907366448308"
                 data-ad-slot="4228407316"
                 data-ad-format="horizontal"
                 data-full-width-responsive="true"></ins>
          </div>
        </div>
        <CrossLinks exclude="dev" lang={lang} />
      </main>

      <!-- Footer ad banner -->
      <div class="shrink-0 px-6 py-3 border-t border-[var(--color-border)]" style="min-height: 100px;">
        <div class="mx-auto max-w-[728px]" style="min-height: 90px;">
          <ins class="adsbygoogle"
               style="display:block; min-height: 90px;"
               data-ad-client="ca-pub-8761907366448308"
               data-ad-slot="4228407316"
               data-ad-format="horizontal"
               data-full-width-responsive="true"></ins>
        </div>
      </div>

      <!-- Footer -->
      <footer class="px-4 py-2 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-xs text-[var(--color-text-muted)]">
        <div class="flex items-center justify-between mb-2">
          <span>{t(lang, "footerTagline")}</span>
          <span class="flex items-center gap-3">
            <a href={lang === "es" ? "/es/privacy-policy/" : "/privacy-policy/"} class="hover:text-[var(--color-accent)] transition-colors">{t(lang, "footerPrivacy")}</a>
            <a href="https://buymeacoffee.com/allopen" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{t(lang, "footerCoffee")}</a>
          </span>
        </div>
        <form id="feedback-form" action="https://formspree.io/f/mpqoddwl" method="POST" class="flex gap-2">
          <input type="hidden" name="app" value="JSONCraft" />
          <input type="hidden" name="page" value="" />
          <input type="hidden" name="_subject" value="" />
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="text" name="message" placeholder={t(lang, "feedbackPlaceholder")} required aria-label={t(lang, "feedbackPlaceholder")} class="flex-1 !py-1 !px-2 !text-[11px]" />
          <button type="submit" class="px-2 py-1 rounded text-[10px] bg-[var(--color-bg-tertiary)] hover:text-[var(--color-accent)] transition-colors" style="cursor: pointer;">{t(lang, "feedbackSend")}</button>
        </form>
      </footer>
    </div>

    <CookieConsent lang={lang} />

    <script is:inline>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        document.documentElement.classList.toggle("light");
        const isLight = document.documentElement.classList.contains("light");
        localStorage.setItem("jsoncraft-theme", isLight ? "light" : "dark");
        document.getElementById("icon-dark")?.classList.toggle("hidden", isLight);
        document.getElementById("icon-light")?.classList.toggle("hidden", !isLight);
        window.dispatchEvent(new CustomEvent("theme-changed", { detail: { light: isLight } }));
      });

      // Update icons on load
      const isLight = document.documentElement.classList.contains("light");
      document.getElementById("icon-dark")?.classList.toggle("hidden", isLight);
      document.getElementById("icon-light")?.classList.toggle("hidden", !isLight);

      // Mobile menu toggle
      document.getElementById("menu-toggle")?.addEventListener("click", () => {
        document.getElementById("sidebar")?.classList.toggle("-translate-x-full");
      });
    </script>

    <!-- Feedback form: AJAX submit + toast (no page reload) -->
    <script>
      (function () {
        const form = document.getElementById('feedback-form');
        if (!(form instanceof HTMLFormElement)) return;

        const isEs = document.documentElement.lang === 'es';
        const MSG = {
          success: isEs ? '¡Gracias por tu feedback!' : 'Thanks for your feedback!',
          error: isEs ? 'Error al enviar. Inténtalo más tarde.' : 'Error sending. Please try again later.',
        };

        function showToast(text, isError) {
          const toast = document.createElement('div');
          toast.setAttribute('role', 'status');
          toast.setAttribute('aria-live', 'polite');
          toast.textContent = text;
          Object.assign(toast.style, {
            position: 'fixed',
            bottom: '24px',
            left: '50%',
            transform: 'translate(-50%, 20px)',
            padding: '12px 20px',
            borderRadius: '8px',
            background: isError ? '#dc2626' : '#059669',
            color: '#fff',
            fontSize: '13px',
            fontWeight: '500',
            zIndex: '9999',
            boxShadow: '0 10px 30px rgba(0,0,0,0.35)',
            opacity: '0',
            transition: 'opacity .25s ease, transform .25s ease',
            cursor: 'pointer',
            maxWidth: '90vw',
          });
          toast.title = isEs ? 'Clic para cerrar' : 'Click to dismiss';
          document.body.appendChild(toast);
          requestAnimationFrame(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translate(-50%, 0)';
          });
          let dismissed = false;
          const dismiss = () => {
            if (dismissed) return;
            dismissed = true;
            toast.style.opacity = '0';
            toast.style.transform = 'translate(-50%, 20px)';
            setTimeout(() => toast.remove(), 300);
          };
          toast.addEventListener('click', dismiss);
          setTimeout(dismiss, 5000);
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const submitBtn = form.querySelector('button[type="submit"]');
          const data = new FormData(form);
          data.set('page', location.href);
          const appName = String(data.get('app') || 'JSONCraft');
          data.set('_subject', `[${appName}] ${location.pathname}`);
          if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = true;
          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: data,
              headers: { Accept: 'application/json' },
            });
            if (res.ok) {
              showToast(MSG.success, false);
              form.reset();
            } else {
              showToast(MSG.error, true);
            }
          } catch {
            showToast(MSG.error, true);
          } finally {
            if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = false;
          }
        });
      })();
    </script>
  </body>
</html>
