---
import Layout from "../layouts/Layout.astro";
import HashGenerator from "../components/HashGenerator.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("hash", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="hash">
  <HashGenerator client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["base64", "uuid", "url-encode"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
