---
import Layout from "../layouts/Layout.astro";
import JsonDiff from "../components/JsonDiff.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
---

<Layout
  title="JSON Diff — Compare JSON Online Side by Side"
  description="Compare two JSON documents online for free. See additions, deletions, and changes highlighted side by side. Semantic comparison — key order doesn't matter. No upload needed."
  activeToolId="diff"
>
  <JsonDiff client:load />
  <SeoContent
    heading="Compare JSON Documents Side by Side"
    text="Paste two JSON documents to instantly see what changed. JSONCraft compares semantically, so different key ordering won't produce false differences. Additions are highlighted in green, deletions in red, with a summary of total changes."
    relatedToolIds={["formatter", "viewer", "jsonpath"]}
  />
  <SeoBlock
    heading="About JSON Diff"
    text="Compare two JSON documents semantically — key order doesn't matter. See exactly what was added, removed, or changed with color-coded highlighting and a summary of total changes."
    features={[
      "Semantic comparison (key order independent)",
      "Color-coded additions and deletions",
      "Change summary with line counts",
      "Swap sides with one click",
      "Identifies identical documents",
    ]}
  />
</Layout>
