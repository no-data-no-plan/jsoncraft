---
import Layout from "../layouts/Layout.astro";
import JsonDiff from "../components/JsonDiff.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("diff", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="diff">
  <JsonDiff client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "viewer", "jsonpath"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
