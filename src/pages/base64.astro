---
import Layout from "../layouts/Layout.astro";
import Base64Tool from "../components/Base64Tool.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("base64", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="base64">
  <Base64Tool client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["url-encode", "hash", "formatter"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
