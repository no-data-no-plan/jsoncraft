---
import Layout from "../layouts/Layout.astro";
import XmlFormatter from "../components/XmlFormatter.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("xml-formatter", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="xml-formatter">
  <XmlFormatter client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "yaml-to-json", "json-to-toml"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="xml-formatter" lang="en" />
</Layout>
