---
import Layout from "../../layouts/Layout.astro";
import JsonSchemaValidator from "../../components/JsonSchemaValidator.svelte";
import SeoContent from "../../components/SeoContent.astro";
import SeoBlock from "../../components/SeoBlock.astro";
import CompareLinks from "../../components/CompareLinks.astro";
import { getPageSeo } from "../../i18n/pages";

const seo = getPageSeo("json-schema-validator", "es")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="json-schema-validator" lang="es">
  <JsonSchemaValidator client:load lang="es" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "viewer", "yaml-validator"]} lang="es" />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} lang="es" />
  <CompareLinks lang="es" competitors={["jsonlint", "codebeautify"]} />
</Layout>
