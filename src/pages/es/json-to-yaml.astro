---
import Layout from "../../layouts/Layout.astro";
import Converter from "../../components/Converter.svelte";
import SeoContent from "../../components/SeoContent.astro";
import SeoBlock from "../../components/SeoBlock.astro";
import { getPageSeo } from "../../i18n/pages";

const seo = getPageSeo("json-to-yaml", "es")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="json-to-yaml" lang="es">
  <Converter client:load fromFormat="json" toFormat="yaml" lang="es" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["yaml-to-json", "formatter", "json-to-toml"]} lang="es" />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} lang="es" />
</Layout>
