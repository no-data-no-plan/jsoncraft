---
import Layout from "../../../layouts/Layout.astro";
import { getAllDocs, docPath, formatDate, CATEGORY_ORDER, CATEGORY_LABELS } from "../../../lib/docs";

const lang = "es" as const;
const docs = await getAllDocs(lang);
const groupedCategories = CATEGORY_ORDER
  .map((cat) => ({ cat, docs: docs.filter((d) => d.data.category === cat) }))
  .filter((g) => g.docs.length > 0);

const description = "Guías prácticas sobre JSON, JSON Schema, JWT, JSONPath y conversión entre formatos. Cada guía enlaza con la herramienta de JSONCraft que la aplica en el navegador.";
---

<Layout title="Guías" description={description} activeToolId="docs" lang={lang} schemaType="CollectionPage">
  <section class="px-4 sm:px-8 py-8 max-w-[56rem] mx-auto">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-wider text-[var(--color-accent-fg)] mb-2">Guías</p>
      <h1 class="text-3xl font-bold text-[var(--color-text-primary)] leading-tight mb-3">Guías del ecosistema JSON</h1>
      <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
        Guías prácticas y técnicas sobre JSON Schema, JWT, JSONPath vs JMESPath, JSON vs YAML vs TOML, parsers streaming, pitfalls de seguridad y compresión.
        Cada guía va con la herramienta de JSONCraft que la aplica en el navegador.
      </p>
    </header>

    {docs.length === 0 && (
      <div class="p-4 rounded border border-[var(--color-border)] text-sm text-[var(--color-text-muted)] bg-[var(--color-bg-secondary)]">
        Sin guías publicadas todavía. Vuelve pronto.
      </div>
    )}

    {groupedCategories.map(({ cat, docs: catDocs }) => (
      <div class="mb-8">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-primary)] mb-3 pb-1 border-b border-[var(--color-border)]">
          {CATEGORY_LABELS[lang][cat]}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {catDocs.map((doc) => (
            <a
              href={docPath(doc)}
              class="block p-4 rounded border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors bg-[var(--color-bg-secondary)]"
            >
              <div class="text-sm font-semibold text-[var(--color-text-primary)] mb-1 leading-snug">{doc.data.title}</div>
              <div class="text-xs text-[var(--color-text-muted)] line-clamp-3 mb-2">{doc.data.description}</div>
              <div class="text-[10px] text-[var(--color-text-muted)] opacity-70">{formatDate(doc.data.publishedAt, lang)}</div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Guides",
  "numberOfItems": docs.length,
  "itemListElement": docs.map((d, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://jsoncraft.dev${docPath(d)}`,
    "name": d.data.title,
  })),
})} />
</Layout>
