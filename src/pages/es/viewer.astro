---
import Layout from "../../layouts/Layout.astro";
import TreeViewer from "../../components/TreeViewer.svelte";
import SeoContent from "../../components/SeoContent.astro";
import SeoBlock from "../../components/SeoBlock.astro";
import CompareLinks from "../../components/CompareLinks.astro";
import { getPageSeo } from "../../i18n/pages";

const seo = getPageSeo("viewer", "es")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="viewer" lang="es">
  <TreeViewer client:load lang="es" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "jsonpath", "diff"]} lang="es" />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} lang="es" />
  <CompareLinks lang="es" competitors={["json-crack", "json-editor-online"]} />
</Layout>
