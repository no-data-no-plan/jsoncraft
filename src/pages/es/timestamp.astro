---
import Layout from "../../layouts/Layout.astro";
import TimestampTool from "../../components/TimestampTool.svelte";
import SeoContent from "../../components/SeoContent.astro";
import SeoBlock from "../../components/SeoBlock.astro";
import { getPageSeo } from "../../i18n/pages";

const seo = getPageSeo("timestamp", "es")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="timestamp" lang="es">
  <TimestampTool client:load lang="es" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["uuid", "hash", "cron"]} lang="es" />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} lang="es" />
</Layout>
