---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.svelte";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import SeoContent from "../components/SeoContent.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("csv-to-json", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="csv-to-json">
  <Converter client:load fromFormat="csv" toFormat="json" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["json-to-csv", "formatter", "viewer"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="csv-to-json" lang="en" />
</Layout>
