---
import Layout from "../layouts/Layout.astro";
import RegexTester from "../components/RegexTester.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("regex", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="regex">
  <RegexTester client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "diff", "url-encode"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
