---
import Layout from "../layouts/Layout.astro";
import JsonPathTool from "../components/JsonPathTool.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("jsonpath", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="jsonpath">
  <JsonPathTool client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["viewer", "formatter", "diff"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="jsonpath" lang="en" />
</Layout>
