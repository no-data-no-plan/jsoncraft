---
import Layout from "../layouts/Layout.astro";
import TreeViewer from "../components/TreeViewer.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import CompareLinks from "../components/CompareLinks.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("viewer", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="viewer">
  <TreeViewer client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "jsonpath", "diff"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <CompareLinks lang="en" competitors={["json-crack", "json-editor-online"]} />
  <FaqSection toolId="viewer" lang="en" />
</Layout>
