---
import Layout from "../layouts/Layout.astro";
import UuidGenerator from "../components/UuidGenerator.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("uuid", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="uuid">
  <UuidGenerator client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["hash", "base64", "timestamp"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
