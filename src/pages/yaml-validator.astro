---
import Layout from "../layouts/Layout.astro";
import YamlValidator from "../components/YamlValidator.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("yaml-validator", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="yaml-validator">
  <YamlValidator client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["yaml-to-json", "formatter", "json-schema-validator"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="yaml-validator" lang="en" />
</Layout>
