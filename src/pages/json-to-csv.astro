---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.svelte";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import SeoContent from "../components/SeoContent.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("json-to-csv", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="json-to-csv">
  <Converter client:load fromFormat="json" toFormat="csv" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["csv-to-json", "formatter", "json-to-yaml"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="json-to-csv" lang="en" />
</Layout>
