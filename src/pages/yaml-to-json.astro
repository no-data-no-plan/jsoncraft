---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.svelte";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import SeoContent from "../components/SeoContent.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("yaml-to-json", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="yaml-to-json">
  <Converter client:load fromFormat="yaml" toFormat="json" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["yaml-validator", "json-to-yaml", "formatter"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="yaml-to-json" lang="en" />
</Layout>
