---
import Layout from "../layouts/Layout.astro";
import JsonToHtmlTable from "../components/JsonToHtmlTable.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("json-to-html-table", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="json-to-html-table">
  <JsonToHtmlTable client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["json-to-csv", "formatter", "viewer"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="json-to-html-table" lang="en" />
</Layout>
