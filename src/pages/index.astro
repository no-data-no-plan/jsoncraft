---
import Layout from "../layouts/Layout.astro";
import JsonFormatter from "../components/JsonFormatter.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import CompareLinks from "../components/CompareLinks.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("formatter", "en")!;
---

<Layout
  title={seo.title}
  description={seo.description}
  activeToolId="formatter"
>
  <JsonFormatter client:load />
  <SeoContent
    heading={seo.seoHeading}
    text={seo.seoText}
    relatedToolIds={["viewer", "diff", "json-to-yaml"]}
  />
  <SeoBlock
    heading={seo.seoBlockHeading}
    text={seo.seoBlockText}
    features={seo.seoFeatures}
  />
  <CompareLinks lang="en" competitors={["codebeautify", "devtoys", "json-crack", "json-editor-online", "jsonlint"]} />
</Layout>
