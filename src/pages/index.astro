---
import Layout from "../layouts/Layout.astro";
import JsonFormatter from "../components/JsonFormatter.svelte";
import SeoBlock from "../components/SeoBlock.astro";
---

<Layout
  title="JSON Formatter & Validator"
  description="Free online JSON formatter, validator, and minifier. Format, validate, and beautify JSON instantly. No ads, no tracking, 100% client-side."
  activeToolId="formatter"
>
  <JsonFormatter client:load />
  <SeoBlock
    heading="About this tool"
    text="JSONCraft's formatter instantly validates, beautifies, and minifies your JSON. Paste or drop a file and get real-time syntax validation with clear error messages pointing to the exact line and column."
    features={[
      "Format with 2 spaces, 4 spaces, or tabs",
      "Minify JSON to a single compact line",
      "Real-time validation as you type",
      "Upload .json files or drag and drop",
      "Download formatted results",
    ]}
  />
</Layout>
