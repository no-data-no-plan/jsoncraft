---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.svelte";
import SeoBlock from "../components/SeoBlock.astro";
import SeoContent from "../components/SeoContent.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("toml-to-json", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="toml-to-json">
  <Converter client:load fromFormat="toml" toFormat="json" />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["json-to-toml", "formatter", "yaml-to-json"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
