---
import LangToggle from "../components/LangToggle.astro";
import "../styles/global.css";
import { tools } from "../lib/tools";

const popularIds = [
  "formatter",
  "diff",
  "viewer",
  "jsonpath",
  "json-to-yaml",
  "yaml-to-json",
  "regex",
  "base64",
];
const popular = popularIds.map(id => tools.find(t => t.id === id)).filter(Boolean);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Page Not Found — JSONCraft</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/fonts/fonts.css" />

  <!-- Google Analytics 4 — Consent Mode v2. AdSense intentionally excluded: Google
       program policies prohibit serving ads on 404 pages. -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      analytics_storage: 'denied',
      wait_for_update: 500,
    });
      // [GEO-GATE-V1] analytics_storage stays denied for EU/EEA/UK; granted elsewhere.
      // Fires inside wait_for_update window (500ms) so non-EU pings still flow.
      // CF /cdn-cgi/trace responds <100ms — well within the budget.
      fetch("/cdn-cgi/trace").then(function(r){return r.text();}).then(function(t){
        var m = t.match(/loc=([A-Z]{2})/);
        var cc = m ? m[1] : "";
        var EU = ["AT","BE","BG","CY","CZ","DE","DK","EE","ES","FI","FR","GR","HR","HU","IE","IT","LT","LU","LV","MT","NL","PL","PT","RO","SE","SI","SK","GB","UK","IS","LI","NO","CH"];
        if (cc && EU.indexOf(cc) === -1) {
          gtag("consent","update",{analytics_storage:"granted"});
        }
      }).catch(function(){});
    gtag('js', new Date());
    gtag('config', 'G-PV8S3GBCDY', { anonymize_ip: true });
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PV8S3GBCDY"></script>

  <style>
    html[lang="es"] [data-lang="en"] { display: none !important; }
    html:not([lang="es"]) [data-lang="es"] { display: none !important; }
  </style>
  <script is:inline>
    (function() {
      if (localStorage.getItem("jsoncraft-theme") === "light") {
        document.documentElement.classList.add("light");
      }
      var isEs = location.pathname === '/es' || location.pathname.indexOf('/es/') === 0;
      if (isEs) {
        document.documentElement.lang = 'es';
        document.title = 'Página no encontrada — JSONCraft';
      }
    })();
  </script>
</head>
<body style="background: var(--color-bg-primary); color: var(--color-text-primary);">
  <div class="absolute top-4 right-4 z-30">
    <span data-lang="en"><LangToggle lang="en" enPath="/" esPath="/es/" /></span>
    <span data-lang="es"><LangToggle lang="es" enPath="/" esPath="/es/" /></span>
  </div>
  <div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <div class="text-center max-w-2xl">
      <p class="text-6xl font-bold mb-4" style="color: var(--color-accent-fg);">404</p>

      <div data-lang="en">
        <h1 class="text-xl font-semibold mb-2" style="color: var(--color-text-primary);">Page not found</h1>
        <p class="text-sm mb-6" style="color: var(--color-text-muted);">
          The page you're looking for doesn't exist or has been moved. Here are some popular tools instead:
        </p>
      </div>
      <div data-lang="es">
        <h1 class="text-xl font-semibold mb-2" style="color: var(--color-text-primary);">Página no encontrada</h1>
        <p class="text-sm mb-6" style="color: var(--color-text-muted);">
          La página que buscas no existe o ha sido movida. Aquí tienes algunas herramientas populares:
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-8">
        {popular.map((t) => (
          <>
            <a data-lang="en" href={t!.path} class="px-3 py-2 rounded text-xs font-medium transition-colors"
               style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); color: var(--color-text-primary);">
              {t!.name}
            </a>
            <a data-lang="es" href={`/es${t!.path === "/" ? "" : t!.path}`} class="px-3 py-2 rounded text-xs font-medium transition-colors"
               style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); color: var(--color-text-primary);">
              {t!.name}
            </a>
          </>
        ))}
      </div>

      <a data-lang="en" href="/" class="inline-block px-4 py-2 rounded text-sm font-medium transition-colors" style="background: var(--color-accent); color: #fff;">
        Browse all tools
      </a>
      <a data-lang="es" href="/es/" class="inline-block px-4 py-2 rounded text-sm font-medium transition-colors" style="background: var(--color-accent); color: #fff;">
        Ver todas las herramientas
      </a>
    </div>
  </div>
</body>
</html>
