---
import Layout from "../layouts/Layout.astro";
import JsonSchemaValidator from "../components/JsonSchemaValidator.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("json-schema-validator", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="json-schema-validator">
  <JsonSchemaValidator client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "viewer", "yaml-validator"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
</Layout>
