---
import Layout from "../layouts/Layout.astro";
import UrlEncodeTool from "../components/UrlEncodeTool.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("url-encode", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="url-encode">
  <UrlEncodeTool client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["base64", "hash", "regex"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="url-encode" lang="en" />
</Layout>
