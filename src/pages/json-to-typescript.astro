---
import Layout from "../layouts/Layout.astro";
import JsonToTypescript from "../components/JsonToTypescript.svelte";
import SeoContent from "../components/SeoContent.astro";
import SeoBlock from "../components/SeoBlock.astro";
import FaqSection from "../components/FaqSection.astro";
import { getPageSeo } from "../i18n/pages";

const seo = getPageSeo("json-to-typescript", "en")!;
---

<Layout title={seo.title} description={seo.description} activeToolId="json-to-typescript">
  <JsonToTypescript client:load />
  <SeoContent heading={seo.seoHeading} text={seo.seoText} relatedToolIds={["formatter", "viewer", "json-to-yaml"]} />
  <SeoBlock heading={seo.seoBlockHeading} text={seo.seoBlockText} features={seo.seoFeatures} />
  <FaqSection toolId="json-to-typescript" lang="en" />
</Layout>
