{
  "name": "jsoncraft",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bash scripts/check-svelte-state.sh && astro build && node scripts/early-hints.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "prebuild": "bash scripts/update-sitemap-lastmod.sh"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.0.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@tailwindcss/vite": "^4.2.2",
    "ajv": "^8.18.0",
    "astro": "^6.0.8",
    "codemirror": "^6.0.2",
    "diff": "^8.0.4",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "papaparse": "^5.5.3",
    "smol-toml": "^1.6.0",
    "svelte": "^5.54.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/diff": "^7.0.2",
    "@types/papaparse": "^5.5.2",
    "vitest": "^4.1.3"
  }
}
